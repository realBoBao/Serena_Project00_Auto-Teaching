# Ignore Python files — prevent Buildpacks from detecting Python
*.py
requirements.txt
.venv/
__pycache__/
*.pyc

# Ignore Node.js local artifacts
node_modules/
.npm/

# Ignore git
.git/
.gitignore

# Ignore docs
docs/
*.md
LICENSE

# Ignore IDE
.vscode/
.idea/

# Ignore tests
tests/
coverage/

# Ignore local data
data/
*.db
*.sqlite
.env
